# Copy this file to `.env` and fill in your tokens. `.env` is gitignored.
# Both are fine-grained GitHub tokens scoped to ONLY the candy-lab repo.

# Used at publish time (electron-builder). Contents: Read and write.
GH_TOKEN=

# Baked into the app for downloading updates. Contents: Read-only.
CANDY_LAB_UPDATE_TOKEN=

# Code signing. Path to a .pfx/.p12 cert + its password. A self-signed cert is
# generated into certs/ by default; replace with a real CA cert to upgrade.
CSC_LINK=certs/candy-lab.pfx
CSC_KEY_PASSWORD=

# ── Supabase (Releases CMS) ────────────────────────────────────────────────
# These power the Releases feature. The `MAIN_VITE_` prefix is required so
# electron-vite injects them into the MAIN process only (never the renderer) —
# the client and key stay out of the sandboxed UI bundle. See supabase/README.md.
#
# Your project URL, e.g. https://xxxxxxxx.supabase.co
MAIN_VITE_SUPABASE_URL=
# Use the SERVICE ROLE key: it lives in the trusted main process, never reaches
# the renderer, and lets the DB stay fully locked down (RLS on, no public access).
MAIN_VITE_SUPABASE_KEY=
# The ANON (public) key — used only for the Google sign-in flow (user auth).
# Project Settings → API → "anon"/"publishable" key.
MAIN_VITE_SUPABASE_ANON_KEY=
